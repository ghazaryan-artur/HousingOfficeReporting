<Window x:Class="HousingOffice.Views.AddHouseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ավելացնել տուն"
        Height="360" Width="480"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource AppFont}" FontSize="14"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Փողոց" FontWeight="Bold"/>
        <TextBox Grid.Row="1" x:Name="StreetBox" Margin="0,4,0,12" Padding="6,4" Style="{StaticResource SearchBox}"/>

        <TextBlock Grid.Row="2" Text="Համար" FontWeight="Bold"/>
        <TextBox Grid.Row="3" x:Name="NumberBox" Margin="0,4,0,12" Padding="6,4" Style="{StaticResource SearchBox}"/>

        <TextBlock Grid.Row="4" Text="Ամբողջ անվանում (կրկնվող չլինի)" FontWeight="Bold"/>
        <TextBox Grid.Row="5" x:Name="NameBox" Margin="0,4,0,8" Padding="6,4" Style="{StaticResource SearchBox}"/>

        <TextBlock Grid.Row="6" TextWrapping="Wrap" Foreground="#5c7a67" FontSize="12"
                   Text="Անվանում որպես Excel-ում՝ '_' կիրառելով, օր. Մոլդովական_1"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Չեղարկել" Style="{StaticResource ToolbarButtonSecondary}" Click="Cancel_Click" MinWidth="100"/>
            <Button Content="Ավելացնել" Style="{StaticResource ToolbarButton}" Click="Ok_Click" MinWidth="100"/>
        </StackPanel>
    </Grid>
</Window>
