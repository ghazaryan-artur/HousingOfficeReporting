<Application x:Class="HousingOffice.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="AppFont">Segoe UI, Arial Unicode MS, Sylfaen</FontFamily>

            <Style TargetType="Button" x:Key="ToolbarButton">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="14,8"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="#0d6efd"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#0b5ed7"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Button" x:Key="ToolbarButtonSecondary" BasedOn="{StaticResource ToolbarButton}">
                <Setter Property="Background" Value="#6c757d"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#5c636a"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Button" x:Key="ToolbarButtonDanger" BasedOn="{StaticResource ToolbarButton}">
                <Setter Property="Background" Value="#dc3545"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#bb2d3b"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="TextBox" x:Key="SearchBox">
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="BorderBrush" Value="#dee2e6"/>
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="GridLinesVisibility" Value="All"/>
                <Setter Property="RowHeight" Value="30"/>
                <Setter Property="AlternatingRowBackground" Value="#f8f9fa"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#dee2e6"/>
                <Setter Property="VerticalGridLinesBrush" Value="#dee2e6"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Background" Value="#e9ecef"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="BorderBrush" Value="#dee2e6"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
