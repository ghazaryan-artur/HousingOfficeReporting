<Application x:Class="HousingOffice.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="AppFont">Segoe UI, Arial Unicode MS, Sylfaen</FontFamily>

            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2f7d52"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#cfe8da"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>

            <Style TargetType="Button" x:Key="ToolbarButton">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="14,8"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="#1e7145"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#175a37"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Button" x:Key="ToolbarButtonSecondary" BasedOn="{StaticResource ToolbarButton}">
                <Setter Property="Background" Value="#6b9c54"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#57823f"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Button" x:Key="ToolbarButtonDanger" BasedOn="{StaticResource ToolbarButton}">
                <Setter Property="Background" Value="#dc3545"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#bb2d3b"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Button" x:Key="ToolbarButtonWarning" BasedOn="{StaticResource ToolbarButton}">
                <Setter Property="Background" Value="#e0a800"/>
                <Setter Property="Foreground" Value="#3d3000"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#c69500"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="#d8d8d8"/>
                        <Setter Property="Foreground" Value="#8a8a8a"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Button" x:Key="QuietIconButton">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="6,3"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#7fa38c"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#d9e8de"/>
                        <Setter Property="Foreground" Value="#175a37"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="TextBox" x:Key="SearchBox">
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="BorderBrush" Value="#c7dbcd"/>
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="GridLinesVisibility" Value="All"/>
                <Setter Property="RowHeight" Value="30"/>
                <Setter Property="AlternatingRowBackground" Value="#f3f8f4"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#c7dbcd"/>
                <Setter Property="VerticalGridLinesBrush" Value="#c7dbcd"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Background" Value="#dcebe1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="BorderBrush" Value="#c7dbcd"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
