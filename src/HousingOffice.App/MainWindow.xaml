<Window x:Class="HousingOffice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HousingOffice.ViewModels"
        Title="Համատիրության հաշվառում"
        Height="720" Width="1400"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource AppFont}">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" Background="#f1f3f5" Padding="12,10" BorderBrush="#dee2e6" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="➕  Ավելացնել տուն" Style="{StaticResource ToolbarButton}" Command="{Binding AddHouseCommand}"/>
                    <Button Content="👤  Ավելացնել բնակիչ" Style="{StaticResource ToolbarButton}" Command="{Binding AddResidentCommand}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Text="Հաշվարկվող ամիս:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                    <ComboBox Width="60" SelectedItem="{Binding CurrentMonth}" VerticalAlignment="Center">
                        <ComboBox.ItemsSource>
                            <x:Array Type="{x:Type sys:Int32}" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                <sys:Int32>1</sys:Int32><sys:Int32>2</sys:Int32><sys:Int32>3</sys:Int32>
                                <sys:Int32>4</sys:Int32><sys:Int32>5</sys:Int32><sys:Int32>6</sys:Int32>
                                <sys:Int32>7</sys:Int32><sys:Int32>8</sys:Int32><sys:Int32>9</sys:Int32>
                                <sys:Int32>10</sys:Int32><sys:Int32>11</sys:Int32><sys:Int32>12</sys:Int32>
                            </x:Array>
                        </ComboBox.ItemsSource>
                    </ComboBox>
                    <Button x:Name="YearButton" Margin="16,0,0,0" Command="{Binding OpenYearPickerCommand}"
                            Style="{StaticResource ToolbarButtonSecondary}"
                            ToolTip="Փոխել տարին">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅  "/>
                            <TextBlock Text="{Binding CurrentYear}"/>
                            <TextBlock Text=" ▾" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Popup x:Name="YearPopup"
                           IsOpen="{Binding IsYearPickerOpen, Mode=TwoWay}"
                           StaysOpen="False" Placement="Bottom" AllowsTransparency="True"
                           PlacementTarget="{Binding ElementName=YearButton}">
                        <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" Padding="8" CornerRadius="6">
                            <StackPanel MinWidth="160">
                                <TextBlock Text="Ընտրել տարի" FontWeight="Bold" Margin="4,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding AvailableYears}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Style="{StaticResource ToolbarButtonSecondary}"
                                                    Margin="0,2"
                                                    Command="{Binding DataContext.PickYearCommand, ElementName=YearPopup}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Separator Margin="0,6"/>
                                <Button Content="➕ Նոր տարի" Style="{StaticResource ToolbarButton}"
                                        Command="{Binding DataContext.CreateNewYearCommand, ElementName=YearPopup}"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#e9ecef" Padding="10,6" BorderBrush="#dee2e6" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" FontSize="12" Foreground="#495057"/>

                <TextBlock DockPanel.Dock="Right" Text="Powered by Artur Ghazaryan"
                           FontSize="11" Foreground="#adb5bd" FontStyle="Italic"
                           VerticalAlignment="Center"/>

                <Button x:Name="ActionsButton" DockPanel.Dock="Right"
                        Style="{StaticResource QuietIconButton}"
                        Command="{Binding OpenActionsMenuCommand}"
                        ToolTip="Հատուկ գործողություններ (մասնագետի համար)"
                        Content="⚙" Margin="0,0,10,0"/>
                <Popup x:Name="ActionsPopup"
                       IsOpen="{Binding IsActionsMenuOpen, Mode=TwoWay}"
                       StaysOpen="False" Placement="Top" AllowsTransparency="True"
                       PlacementTarget="{Binding ElementName=ActionsButton}">
                    <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" Padding="8" CornerRadius="6">
                        <StackPanel MinWidth="220">
                            <TextBlock Text="Հատուկ գործողություններ" FontWeight="Bold" FontSize="12" Foreground="#868e96" Margin="4,0,0,6"/>
                            <Button Content="📥  Ներմուծել Excel" Style="{StaticResource ToolbarButtonSecondary}"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,4"
                                    Command="{Binding DataContext.ImportXlsmCommand, ElementName=ActionsPopup}"/>
                            <Button Content="📤  Արտահանել Excel" Style="{StaticResource ToolbarButtonSecondary}"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,4"
                                    Command="{Binding DataContext.ExportXlsmCommand, ElementName=ActionsPopup}"/>
                            <Separator Margin="0,4"/>
                            <Button Content="🗑  Հեռացնել այս տունը" Style="{StaticResource ToolbarButtonDanger}"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding DataContext.DeleteHouseCommand, ElementName=ActionsPopup}"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </DockPanel>
        </Border>

        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Top" Padding="16,10" Background="White" BorderBrush="#dee2e6" BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="False">
                    <Button x:Name="HouseButton" DockPanel.Dock="Left"
                            Style="{StaticResource ToolbarButtonSecondary}"
                            Command="{Binding OpenHousePickerCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠  " FontSize="18"/>
                            <TextBlock FontSize="18" FontWeight="Bold"
                                       Text="{Binding SelectedHouse.DisplayName, FallbackValue='Ընտրեք տուն →'}"/>
                            <TextBlock Text=" ▾" Margin="6,0,0,0" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Popup x:Name="HousePopup"
                           IsOpen="{Binding IsHousePickerOpen, Mode=TwoWay}"
                           StaysOpen="False" Placement="Bottom" AllowsTransparency="True"
                           PlacementTarget="{Binding ElementName=HouseButton}">
                        <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" Padding="10" CornerRadius="6">
                            <StackPanel Width="320">
                                <TextBlock Text="Տներ" FontSize="16" FontWeight="Bold" Margin="2,0,0,8"/>
                                <TextBox Style="{StaticResource SearchBox}"
                                         Text="{Binding HousesFilter, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="Որոնել..." Margin="0,0,0,8"/>
                                <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding HousesView}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding DisplayName}"
                                                        Style="{StaticResource ToolbarButtonSecondary}"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Margin="0,2"
                                                        Command="{Binding DataContext.PickHouseCommand, ElementName=HousePopup}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Popup>
                </DockPanel>
            </Border>
            <DataGrid ItemsSource="{Binding Residents}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      SelectionUnit="Cell"
                      HeadersVisibility="Column"
                      FrozenColumnCount="2"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <DataGrid.Resources>
                    <Style x:Key="ReadonlyCol" TargetType="DataGridTextColumn">
                        <Setter Property="IsReadOnly" Value="True"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N" Binding="{Binding RowNumber}" IsReadOnly="True" Width="4*"/>
                    <DataGridTextColumn Header="Անուն, ազգանուն" Binding="{Binding FullName}" Width="20*"/>
                    <DataGridTextColumn Header="Ընդ. ք/մ" Binding="{Binding SquareMeters, StringFormat=N2}" Width="7*"/>
                    <DataGridTextColumn Header="Դեբիտ." Binding="{Binding DebitDebt, StringFormat=N0}" Width="8*"/>
                    <DataGridTextColumn Header="Կրեդիտ." Binding="{Binding CreditDebt, StringFormat=N0}" Width="8*"/>
                    <DataGridTextColumn Header="Հաշվարկ" Binding="{Binding MonthlyCharge, StringFormat=N0}" Width="8*"/>
                    <DataGridTextColumn Header="1" Binding="{Binding P1, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="2" Binding="{Binding P2, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="3" Binding="{Binding P3, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="4" Binding="{Binding P4, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="5" Binding="{Binding P5, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="6" Binding="{Binding P6, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="7" Binding="{Binding P7, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="8" Binding="{Binding P8, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="9" Binding="{Binding P9, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="10" Binding="{Binding P10, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="11" Binding="{Binding P11, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="12" Binding="{Binding P12, StringFormat=N0}" Width="6*"/>
                    <DataGridTextColumn Header="Ընդանուր" Binding="{Binding PaidTotal, StringFormat=N0}" Width="9*" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Background" Value="#fff3cd"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Զիջվող" Binding="{Binding DiscountAmount, StringFormat=N0}" Width="8*"/>
                    <DataGridTextColumn Header="Վերջն. մնացորդ" Binding="{Binding FinalBalance, StringFormat=N0}" Width="11*" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Background" Value="#d1e7dd"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Նշում" Binding="{Binding Note}" Width="14*"/>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Հեռացնել բնակչին"
                                  Command="{Binding PlacementTarget.DataContext.DeleteResidentCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Window>
