<Window x:Class="HousingOffice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HousingOffice.ViewModels"
        Title="Համատիրության հաշվառում"
        Height="720" Width="1400"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource AppFont}">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" Background="#f1f3f5" Padding="12,10" BorderBrush="#dee2e6" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="➕  Ավելացնել տուն" Style="{StaticResource ToolbarButton}" Command="{Binding AddHouseCommand}"/>
                    <Button Content="👤  Ավելացնել բնակիչ" Style="{StaticResource ToolbarButton}" Command="{Binding AddResidentCommand}"/>
                    <Rectangle Width="1" Fill="#ced4da" Margin="6,4"/>
                    <Button Content="📥  Ներմուծել Excel" Style="{StaticResource ToolbarButtonSecondary}" Command="{Binding ImportXlsmCommand}"/>
                    <Button Content="📤  Արտահանել Excel" Style="{StaticResource ToolbarButtonSecondary}" Command="{Binding ExportXlsmCommand}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Text="Հաշվարկվող ամիս:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                    <ComboBox Width="60" SelectedItem="{Binding CurrentMonth}" VerticalAlignment="Center">
                        <ComboBox.ItemsSource>
                            <x:Array Type="{x:Type sys:Int32}" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                <sys:Int32>1</sys:Int32><sys:Int32>2</sys:Int32><sys:Int32>3</sys:Int32>
                                <sys:Int32>4</sys:Int32><sys:Int32>5</sys:Int32><sys:Int32>6</sys:Int32>
                                <sys:Int32>7</sys:Int32><sys:Int32>8</sys:Int32><sys:Int32>9</sys:Int32>
                                <sys:Int32>10</sys:Int32><sys:Int32>11</sys:Int32><sys:Int32>12</sys:Int32>
                            </x:Array>
                        </ComboBox.ItemsSource>
                    </ComboBox>
                    <Button x:Name="YearButton" Margin="16,0,0,0" Command="{Binding OpenYearPickerCommand}"
                            Style="{StaticResource ToolbarButtonSecondary}"
                            ToolTip="Փոխել տարին">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅  "/>
                            <TextBlock Text="{Binding CurrentYear}"/>
                            <TextBlock Text=" ▾" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Popup x:Name="YearPopup"
                           IsOpen="{Binding IsYearPickerOpen, Mode=TwoWay}"
                           StaysOpen="False" Placement="Bottom" AllowsTransparency="True"
                           PlacementTarget="{Binding ElementName=YearButton}">
                        <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" Padding="8" CornerRadius="6">
                            <StackPanel MinWidth="160">
                                <TextBlock Text="Ընտրել տարի" FontWeight="Bold" Margin="4,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding AvailableYears}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Style="{StaticResource ToolbarButtonSecondary}"
                                                    Margin="0,2"
                                                    Command="{Binding DataContext.PickYearCommand, ElementName=YearPopup}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Separator Margin="0,6"/>
                                <Button Content="➕ Նոր տարի" Style="{StaticResource ToolbarButton}"
                                        Command="{Binding DataContext.CreateNewYearCommand, ElementName=YearPopup}"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#e9ecef" Padding="10,6" BorderBrush="#dee2e6" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" FontSize="12" Foreground="#495057"/>
                <TextBlock DockPanel.Dock="Right" Text="Powered by Artur Ghazaryan"
                           FontSize="11" Foreground="#adb5bd" FontStyle="Italic"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" LastChildFill="True" Background="#fafbfc">
                <Border DockPanel.Dock="Top" Padding="10,10,10,6">
                    <StackPanel>
                        <TextBlock Text="Տներ" FontSize="16" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding HousesFilter, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Որոնել..."/>
                    </StackPanel>
                </Border>
                <Border DockPanel.Dock="Bottom" Padding="10,6,10,10">
                    <Button Content="🗑  Հեռացնել այս տունը"
                            Style="{StaticResource ToolbarButtonDanger}"
                            Command="{Binding DeleteHouseCommand}"
                            HorizontalAlignment="Stretch"/>
                </Border>
                <ListBox ItemsSource="{Binding HousesView}"
                         SelectedItem="{Binding SelectedHouse}"
                         BorderThickness="0" Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#dee2e6"/>

            <DockPanel Grid.Column="2" LastChildFill="True">
                <Border DockPanel.Dock="Top" Padding="16,12" Background="White" BorderBrush="#dee2e6" BorderThickness="0,0,0,1">
                    <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding SelectedHouse.DisplayName, FallbackValue='Ընտրեք տուն →'}"/>
                </Border>
                <DataGrid ItemsSource="{Binding Residents}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          SelectionUnit="Cell"
                          HeadersVisibility="Column"
                          FrozenColumnCount="2">
                    <DataGrid.Resources>
                        <Style x:Key="ReadonlyCol" TargetType="DataGridTextColumn">
                            <Setter Property="IsReadOnly" Value="True"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N" Binding="{Binding RowNumber}" IsReadOnly="True" Width="40"/>
                        <DataGridTextColumn Header="Անուն, ազգանուն" Binding="{Binding FullName}" Width="200"/>
                        <DataGridTextColumn Header="Մասնա բաժին" Binding="{Binding ShareRaw}" Width="90"/>
                        <DataGridTextColumn Header="Ընդ. ք/մ" Binding="{Binding SquareMeters, StringFormat=N2}" Width="70"/>
                        <DataGridTextColumn Header="Դեբիտ." Binding="{Binding DebitDebt, StringFormat=N0}" Width="80"/>
                        <DataGridTextColumn Header="Կրեդիտ." Binding="{Binding CreditDebt, StringFormat=N0}" Width="80"/>
                        <DataGridTextColumn Header="Հաշվարկ" Binding="{Binding MonthlyCharge, StringFormat=N0}" Width="80"/>
                        <DataGridTextColumn Header="1" Binding="{Binding P1, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="2" Binding="{Binding P2, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="3" Binding="{Binding P3, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="4" Binding="{Binding P4, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="5" Binding="{Binding P5, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="6" Binding="{Binding P6, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="7" Binding="{Binding P7, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="8" Binding="{Binding P8, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="9" Binding="{Binding P9, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="10" Binding="{Binding P10, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="11" Binding="{Binding P11, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="12" Binding="{Binding P12, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="Ընդանուր" Binding="{Binding PaidTotal, StringFormat=N0}" Width="90" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Background" Value="#fff3cd"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Զիջվող" Binding="{Binding DiscountAmount, StringFormat=N0}" Width="80"/>
                        <DataGridTextColumn Header="Վերջն. մնացորդ" Binding="{Binding FinalBalance, StringFormat=N0}" Width="110" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Background" Value="#d1e7dd"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Հեռացնել բնակչին"
                                      Command="{Binding PlacementTarget.DataContext.DeleteResidentCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
